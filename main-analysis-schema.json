{
  "type": "object",
  "properties": {
    "grammar_accuracy": {
      "type": "object",
      "properties": {
        "score": {
          "type": "string",
          "enum": ["PASS", "SO-SO", "FAIL"],
          "description": "Score for grammatical correctness (no BULLSEYE for accuracy)"
        },
        "summary": {
          "type": "string",
          "description": "Brief explanation of the evaluation"
        },
        "alternatives": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "suggestion": {
                "type": "string",
                "description": "Alternative correction"
              },
              "fidelity": {
                "type": "string",
                "enum": ["HIGH", "MEDIUM", "LOW"],
                "description": "How well this alternative matches the provided context/tone/meaning"
              }
            },
            "required": ["suggestion", "fidelity"]
          },
          "description": "List of alternatives with fidelity ratings (only if score is SO-SO or FAIL)",
          "nullable": true
        }
      },
      "required": ["score", "summary"]
    },
